# FastAPI Configuration
DEBUG=True
LOG_LEVEL=INFO

# Local database
# For local dev this uses an in-memory SQLite database, so the API starts
# without PostgreSQL. Data resets when the server restarts.
# If you want Postgres later, replace this with your Postgres connection string.
DATABASE_URL=sqlite+pysqlite:///:memory:

# Security Key
SECRET_KEY=local-dev-secret-key-change-me

# Celery / Redis
REDIS_URL=redis://localhost:6379/0
WORKER_CONCURRENCY=2

